# Copy this file to .env and fill in your Azure values.
# Leave any line BLANK to run that part in stub mode (the demo still works).

# Full Azure AI Foundry project connection string.
# Leave blank unless you have a provisioned, hosted Foundry project.
AZURE_AI_PROJECT_CONNECTION_STRING=

# Azure OpenAI (GPT-4o) — needed for LIVE resume analysis.
# From Azure AI Foundry -> Overview -> API Key, and the endpoint
# (e.g. https://<resource>.openai.azure.com/  — the
#  https://<region>.api.cognitive.microsoft.com/ endpoint also works).
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=

# Optional: set if your GPT-4o deployment is NOT named "gpt-4o".
AZURE_OPENAI_DEPLOYMENT=gpt-4o
